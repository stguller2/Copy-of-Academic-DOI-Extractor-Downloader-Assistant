# .env.example
NODE_ENV=development
PORT=3000
GEMINI_API_KEY=your_gemini_api_key_here
SESSION_SECRET=at_least_32_characters_long_random_string
APP_DOMAIN=http://localhost:3000
LOG_LEVEL=info

# Local LLM - CPU-only by default (no GPU required)
# 0     = CPU-only (default, works on any Linux server)
# "auto" = auto-detect GPU (requires CUDA drivers)
GPU_LAYERS=0
