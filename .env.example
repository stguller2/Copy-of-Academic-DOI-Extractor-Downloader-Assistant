# .env.example
NODE_ENV=development
PORT=3000
GEMINI_API_KEY=your_gemini_api_key_here
SESSION_SECRET=at_least_32_characters_long_random_string
APP_DOMAIN=http://localhost:3000
LOG_LEVEL=info

# Local LLM GPU Configuration
# "auto" = auto-detect (CUDA on Linux+NVIDIA, Metal on Mac, CPU fallback)
# 0     = force CPU-only (safe for any Linux server)
# 32    = offload 32 layers to GPU (requires CUDA or Metal)
GPU_LAYERS=auto
